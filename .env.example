SENCLAW_APP_NAME=senclaw
SENCLAW_NODE_ENV=development
SENCLAW_LOG_LEVEL=info
SENCLAW_GATEWAY_PORT=18789
SENCLAW_WEB_PORT=3000
SENCLAW_DATA_DIR=.senclaw/data
SENCLAW_RUNTIME_PLATFORM=auto
