{
  "name": "@senclaw/storage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "files": ["dist", "drizzle", "scripts"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:check": "drizzle-kit check --config ./drizzle.config.ts",
    "db:migrate": "node ./scripts/db-migrate.js"
  },
  "dependencies": {
    "@senclaw/config": "workspace:^",
    "@senclaw/observability": "workspace:^",
    "@senclaw/protocol": "workspace:^",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.36.4",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "drizzle-kit": "^0.27.2"
  }
}
